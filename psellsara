<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Conteúdo Restrito 👀</title>
    
    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Configurações do Tailwind -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'neon-purple': '#b026ff',
                        'neon-pink': '#ff007f',
                        'dark-bg': '#0a0a0a',
                        'darker-bg': '#050505',
                        'panel-bg': 'rgba(25, 25, 25, 0.7)'
                    },
                    fontFamily: {
                        'inter': ['Inter', 'sans-serif'],
                        'mono': ['Space Mono', 'monospace'],
                    },
                    animation: {
                        'pulse-fast': 'pulse 1.5s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'glitch': 'glitch 1s linear infinite',
                        'float': 'float 3s ease-in-out infinite',
                    },
                    keyframes: {
                        glitch: {
                            '2%, 64%': { transform: 'translate(2px, 0) skew(0deg)' },
                            '4%, 60%': { transform: 'translate(-2px, 0) skew(0deg)' },
                            '62%': { transform: 'translate(0, 0) skew(5deg)' },
                        },
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        }
                    }
                }
            }
        }
    </script>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- Estilos Customizados (Efeito VHS, Noise, Blur) -->
    <style>
        body {
            background-color: #050505;
            color: #ffffff;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
        }

        /* Efeito de Ruído (Film Grain) */
        .noise-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            pointer-events: none;
            z-index: 50;
            opacity: 0.05;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }

        /* Efeito Scanlines (VHS) */
        .scanlines {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            pointer-events: none;
            z-index: 49;
            background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,0) 50%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0.1));
            background-size: 100% 4px;
            opacity: 0.3;
        }

        /* Blur Extremo para conteúdo censurado */
        .extreme-blur {
            filter: blur(15px) brightness(0.7);
            transition: filter 0.3s ease;
        }
        
        .extreme-blur:hover {
            filter: blur(8px) brightness(0.9);
        }

        /* Gradiente de fundo */
        .bg-gradient-radial {
            background: radial-gradient(circle at center, rgba(176, 38, 255, 0.15) 0%, rgba(5, 5, 5, 1) 70%);
        }

        /* Botão com Neon Glow */
        .btn-neon {
            background: linear-gradient(45deg, #b026ff, #ff007f);
            box-shadow: 0 0 20px rgba(176, 38, 255, 0.5), 0 0 40px rgba(255, 0, 127, 0.3);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .btn-neon::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: rgba(255, 255, 255, 0.2);
            transform: rotate(45deg);
            animation: shine 3s infinite;
        }
        
        @keyframes shine {
            0% { left: -150%; }
            100% { left: 150%; }
        }

        .btn-neon:active {
            transform: scale(0.95);
            box-shadow: 0 0 10px rgba(176, 38, 255, 0.8);
        }

        /* Estilo de Mensagem de Chat */
        .chat-bubble {
            background: rgba(25, 25, 25, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 10px 15px;
            margin-bottom: 10px;
            max-width: 85%;
            position: relative;
        }

        .chat-bubble-received {
            border-bottom-left-radius: 2px;
            align-self: flex-start;
        }

        .chat-bubble-sent {
            background: rgba(176, 38, 255, 0.2);
            border-bottom-right-radius: 2px;
            align-self: flex-end;
            border-color: rgba(176, 38, 255, 0.3);
        }
        
        .censored-text {
            background-color: #333;
            color: transparent;
            border-radius: 4px;
            padding: 0 4px;
            user-select: none;
        }
        
        /* Oculta scrollbar mas mantém funcionalidade */
        ::-webkit-scrollbar {
            width: 0px;
            background: transparent;
        }
    </style>
</head>
<body class="bg-darker-bg min-h-screen relative font-inter text-gray-100 flex flex-col items-center justify-start pb-20">

    <!-- Efeitos Globais -->
    <div class="noise-overlay"></div>
    <div class="scanlines"></div>
    <div class="fixed inset-0 bg-gradient-radial z-0 pointer-events-none"></div>

    <!-- Container Principal (Mobile First) -->
    <main class="relative z-10 w-full max-w-md mx-auto px-4 pt-8 flex flex-col items-center">
        
        <!-- Indicador de Status Fake -->
        <div class="flex items-center space-x-2 mb-6 self-start">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
            </span>
            <span class="text-xs text-gray-400 font-mono tracking-wider">STATUS: VAZADO</span>
        </div>

        <!-- 1. HERO SECTION -->
        <section class="w-full flex flex-col items-center text-center mb-10">
            <h1 class="text-3xl sm:text-4xl font-black mb-3 leading-tight tracking-tight text-white drop-shadow-[0_0_10px_rgba(255,255,255,0.3)]">
                “ela disse que era só brincadeira… <br><span class="text-neon-pink animate-pulse">até começar 🍷”</span>
            </h1>
            
            <p class="text-sm text-gray-400 font-mono mb-6">
                o vídeo completo ficou disponível por pouco tempo no privado.
            </p>

            <!-- Video Preview Container -->
            <div class="w-full relative rounded-2xl overflow-hidden mb-6 border border-gray-800 shadow-[0_0_30px_rgba(176,38,255,0.15)] group">
                
                <!-- Imagem com Blur (Substituir por vídeo real aqui) -->
                <div class="relative w-full aspect-[4/5] bg-gray-900 overflow-hidden cursor-pointer" onclick="handleCtaClick()">
                    <!-- 
                        PARA COLOCAR UM VÍDEO REAL:
                        1. Comente ou apague a tag <img> abaixo.
                        2. Descomente a tag <video> e coloque a URL do seu vídeo no src.
                    -->
                    
                    <!-- IMAGEM ATUAL (Desfoque/Blur) -->
                    <img src="https://images.unsplash.com/photo-1571260899304-42507011ec70?q=80&w=600&auto=format&fit=crop" 
                         alt="Preview Censure" 
                         class="w-full h-full object-cover extreme-blur opacity-80" />
                         
                    <!-- VÍDEO REAL (Descomente para usar) -->
                    <!--
                    <video autoplay loop muted playsinline class="w-full h-full object-cover extreme-blur opacity-80">
                        <source src="URL_DO_SEU_VIDEO_AQUI.mp4" type="video/mp4">
                        Seu navegador não suporta vídeos.
                    </video>
                    -->
                    
                    <!-- Sobreposição de Play Button -->
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-20 h-20 bg-black/60 backdrop-blur-md rounded-full flex items-center justify-center border border-white/20 group-hover:scale-110 transition-transform">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10 text-white ml-2">
                                <path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" />
                            </svg>
                        </div>
                    </div>
                    
                    <!-- Aviso flutuante -->
                    <div class="absolute top-4 left-4 bg-red-600/90 text-white text-[10px] font-bold px-2 py-1 rounded backdrop-blur-sm border border-red-500/50">
                        NSFW / RESTRICTED
                    </div>
                    
                    <!-- Tempo do vídeo -->
                    <div class="absolute bottom-4 right-4 bg-black/80 text-white text-xs font-mono px-2 py-1 rounded backdrop-blur-sm">
                        02:47
                    </div>
                </div>
            </div>

            <!-- Contador Regressivo e CTA -->
            <div class="w-full flex flex-col items-center">
                <div class="flex items-center space-x-2 text-neon-pink mb-3 font-mono text-sm font-bold bg-neon-pink/10 px-4 py-2 rounded-full border border-neon-pink/20">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>O link expira em:</span>
                    <span id="countdown">04:59</span>
                </div>

                <button onclick="handleCtaClick()" class="btn-neon w-full py-4 rounded-xl text-white font-black text-lg uppercase tracking-wider flex items-center justify-center space-x-2">
                    <span>Assistir Antes Que Apague 👀</span>
                </button>
                <p class="text-[10px] text-gray-500 mt-3 flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 mr-1">
                        <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" />
                    </svg>
                    Acesso anônimo e seguro
                </p>
            </div>
        </section>

        <!-- 3. PREVIEWS ADICIONAIS -->
        <section class="w-full mb-12">
            <p class="text-xs font-mono text-gray-500 mb-3 ml-1"> MAIS ARQUIVOS DA PASTA (CENSURADO):</p>
            <div class="grid grid-cols-3 gap-2">
                <!-- Thumb 1 -->
                <div class="aspect-square bg-gray-900 rounded-lg overflow-hidden relative cursor-pointer" onclick="handleCtaClick()">
                    <img src="https://images.unsplash.com/photo-1517849845537-4d257902454a?q=80&w=200&auto=format&fit=crop" class="w-full h-full object-cover extreme-blur opacity-60">
                    <div class="absolute inset-0 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white/50">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                        </svg>
                    </div>
                </div>
                <!-- Thumb 2 -->
                <div class="aspect-square bg-gray-900 rounded-lg overflow-hidden relative cursor-pointer" onclick="handleCtaClick()">
                    <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=200&auto=format&fit=crop" class="w-full h-full object-cover extreme-blur opacity-60">
                     <div class="absolute inset-0 flex items-center justify-center">
                         <span class="text-[10px] font-bold bg-black/70 px-1 rounded text-white/70">MP4</span>
                    </div>
                </div>
                <!-- Thumb 3 -->
                <div class="aspect-square bg-gray-900 rounded-lg overflow-hidden relative border border-dashed border-gray-700 flex items-center justify-center cursor-pointer hover:bg-gray-800 transition" onclick="handleCtaClick()">
                    <span class="text-xs font-mono text-neon-purple">+4 arquivos</span>
                </div>
            </div>
        </section>

        <!-- 4. CTA FINAL FLUTUANTE / FIXO BASE -->
        <div class="fixed bottom-0 left-0 w-full p-4 bg-gradient-to-t from-black via-black/90 to-transparent pb-6 z-40">
            <div class="max-w-md mx-auto flex flex-col items-center">
                <p class="text-xs font-bold text-gray-300 mb-2 drop-shadow-md">⚠️ O restante foi movido pro privado</p>
                <button onclick="handleCtaClick()" class="btn-neon w-full py-4 rounded-xl text-white font-black text-lg uppercase tracking-wider shadow-2xl">
                    Acessar Agora
                </button>
            </div>
        </div>

    </main>

    <!-- Script de Lógica -->
    <script>
        // Função para o clique no CTA (Botão ou imagens)
        function handleCtaClick() {
            // Efeito visual no clique
            document.body.style.opacity = '0.5';
            setTimeout(() => {
                document.body.style.opacity = '1';
                
                // REDIRECIONAMENTO PARA O TELEGRAM AQUI
                window.location.href = 'https://t.me/Laurinha_Eighteenbot'; 
                
            }, 150);
        }

        // Lógica do Contador Regressivo (Escassez Falsa)
        function startTimer(durationInSeconds, displayElement) {
            let timer = durationInSeconds, minutes, seconds;
            
            // Verifica se já existe um timer no localStorage para manter a consistência se o usuário recarregar
            const savedTime = localStorage.getItem('presellTimer');
            const savedTimestamp = localStorage.getItem('presellTimestamp');
            const now = Math.floor(Date.now() / 1000);

            if (savedTime && savedTimestamp) {
                const elapsed = now - parseInt(savedTimestamp);
                if (elapsed < parseInt(savedTime)) {
                    timer = parseInt(savedTime) - elapsed;
                }
            }

            const interval = setInterval(function () {
                minutes = parseInt(timer / 60, 10);
                seconds = parseInt(timer % 60, 10);

                minutes = minutes < 10 ? "0" + minutes : minutes;
                seconds = seconds < 10 ? "0" + seconds : seconds;

                displayElement.textContent = minutes + ":" + seconds;
                
                // Piscar vermelho quando faltar menos de 1 minuto
                if (timer < 60) {
                    displayElement.parentElement.classList.add('animate-pulse');
                    displayElement.parentElement.classList.replace('text-neon-pink', 'text-red-500');
                    displayElement.parentElement.classList.replace('bg-neon-pink/10', 'bg-red-500/20');
                    displayElement.parentElement.classList.replace('border-neon-pink/20', 'border-red-500/50');
                }

                if (--timer < 0) {
                    timer = 0;
                    clearInterval(interval);
                    displayElement.textContent = "00:00";
                    displayElement.parentElement.innerHTML = '<span class="text-red-500 font-bold">LINK EXPIRADO! (Tentando reconectar...)</span>';
                    
                    // Opcional: Reiniciar após alguns segundos para não perder o lead
                    setTimeout(() => {
                        localStorage.removeItem('presellTimer');
                        localStorage.removeItem('presellTimestamp');
                        location.reload();
                    }, 5000);
                } else {
                    // Salvar estado atual
                    localStorage.setItem('presellTimer', timer);
                    localStorage.setItem('presellTimestamp', Math.floor(Date.now() / 1000));
                }
            }, 1000);
        }

        // Iniciar tudo quando a página carregar
        window.onload = function () {
            // Inicia o contador (Ex: 4 minutos e 59 segundos)
            const fiveMinutes = 60 * 4 + 59;
            const display = document.querySelector('#countdown');
            startTimer(fiveMinutes, display);
            
            // Impede clique com botão direito para aumentar sensação de restrição
            document.addEventListener('contextmenu', event => event.preventDefault());
        };
    </script>
</body>
</html>
